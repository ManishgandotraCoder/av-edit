{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --prefix front-end",
  "buildCommand": "npm run build --prefix front-end",
  "outputDirectory": "front-end/dist/front-end/browser",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
